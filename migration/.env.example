# ─── Google Sheets ───────────────────────────────────────────────────────────
# ID таблицы — последняя часть URL:
# https://docs.google.com/spreadsheets/d/1ABC123.../edit → 1ABC123...
GOOGLE_SPREADSHEET_ID=

# Путь к JSON-файлу с учётными данными Google Service Account
# Скачать: Google Cloud → IAM → Service Accounts → Ключи → JSON
GOOGLE_SERVICE_ACCOUNT_FILE=migration/service_account.json

# ─── База данных ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lms_user:lms_pass@localhost:5432/lms_db

# ─── Настройки загрузки ──────────────────────────────────────────────────────
# ID менеджера, которому назначить импортированных клиентов
# Оставить пустым — будет взят первый менеджер из БД
DEFAULT_MANAGER_ID=
